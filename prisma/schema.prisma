generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum ContactStatus {
  LEAD
  CUSTOMER
  VIP
  LOST
}

enum ContactSource {
  CSV
  MANUAL
  API
  OTHER
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
}

enum CallOutcome {
  ORDER
  CALL_LATER
  SCHEDULE_CALL
  FAIL
}

enum OrderStatus {
  CREATED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CallbackStatus {
  OPEN
  DONE
  CANCELLED
  MISSED
}

enum AiTaskType {
  CUSTOMER_SUMMARY
  HISTORY_SUMMARY
  NEXT_ACTION
}

enum ImportBatchStatus {
  COMPLETED
  FAILED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  contacts          Contact[]
  productCategories ProductCategory[]
  products          Product[]
  orders            Order[]
  orderItems        OrderItem[]
  callActivities    CallActivity[]
  callbacks         Callback[]
  notes             Note[]
  aiLogs            AiLog[]
  contactImportBatches ContactImportBatch[]
}

model User {
  id            String    @id @default(cuid())
  companyId     String
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole  @default(OPERATOR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignedContacts Contact[]      @relation("ContactAssignedUser")
  orders           Order[]
  callActivities   CallActivity[]
  callbacks        Callback[]
  notes            Note[]
  aiLogs           AiLog[]
  accounts         Account[]
  sessions         Session[]
  contactImportBatches ContactImportBatch[]

  @@index([companyId])
  @@index([companyId, role])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Contact {
  id             String          @id @default(cuid())
  companyId      String
  assignedUserId String?
  status         ContactStatus   @default(LEAD)
  source         ContactSource   @default(MANUAL)
  priority       ContactPriority @default(NORMAL)
  name           String
  phone          String?
  email          String?
  street         String?
  city           String?
  zipCode        String?
  country        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignedUser   User?          @relation("ContactAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  orders         Order[]
  callbacks      Callback[]
  callActivities CallActivity[]
  notes          Note[]
  aiLogs         AiLog[]

  @@unique([companyId, phone])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, assignedUserId])
  @@index([companyId, priority])
  @@index([companyId, source])
}

model ContactImportBatch {
  id          String            @id @default(cuid())
  companyId   String
  actorUserId String
  fileName    String?
  status      ImportBatchStatus
  stats       Json
  createdAt   DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User    @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([companyId, createdAt])
}

model ProductCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model Product {
  id         String   @id @default(cuid())
  companyId  String
  categoryId String?
  name       String
  price      Decimal  @db.Decimal(12, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@index([companyId, categoryId])
}

model Order {
  id         String      @id @default(cuid())
  companyId  String
  contactId  String
  operatorId String
  status     OrderStatus @default(CREATED)
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)
  operator       User           @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  items          OrderItem[]
  callActivities CallActivity[]

  @@index([companyId, contactId])
  @@index([companyId, operatorId])
  @@index([companyId, status])
}

model OrderItem {
  id        String  @id @default(cuid())
  companyId String
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId, orderId])
  @@index([companyId, productId])
}

model CallActivity {
  id             String      @id @default(cuid())
  companyId      String
  contactId      String
  operatorId     String
  callbackId     String?
  orderId        String?
  outcome        CallOutcome
  note           String?
  idempotencyKey String      @default(cuid())
  createdAt      DateTime    @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  operator User      @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  callback Callback? @relation(fields: [callbackId], references: [id], onDelete: SetNull)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([companyId, contactId])
  @@index([companyId, operatorId])
  @@index([companyId, outcome])
  @@index([companyId, createdAt])
  @@unique([companyId, operatorId, idempotencyKey])
}

model Callback {
  id             String         @id @default(cuid())
  companyId      String
  contactId      String
  assignedUserId String
  scheduledAt    DateTime
  status         CallbackStatus @default(OPEN)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)
  assignedUser   User           @relation(fields: [assignedUserId], references: [id], onDelete: Restrict)
  callActivities CallActivity[]

  @@index([companyId, assignedUserId, status, scheduledAt])
  @@index([companyId, contactId])
}

model Note {
  id        String   @id @default(cuid())
  companyId String
  contactId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([companyId, contactId])
  @@index([companyId, authorId])
}

model AiLog {
  id            String     @id @default(cuid())
  companyId     String
  contactId     String
  userId        String
  taskType      AiTaskType
  model         String
  promptSummary String
  output        String
  createdAt     DateTime   @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([companyId, contactId])
  @@index([companyId, userId])
  @@index([companyId, taskType])
  @@index([companyId, createdAt])
}
