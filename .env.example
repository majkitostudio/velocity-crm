DATABASE_URL="postgresql://postgres:postgres@localhost:5432/velocity_crm?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"

# AI / LLM — Production AI Providers deferred (planned after MVP).
# Fake LLM = oficiální vývojový provider. Model vybírá registry + policy přes LLM_{PROFILE}_* env.
LLM_SUMMARY_VENDOR=fake
LLM_SUMMARY_MODEL=fake-1
LLM_RECOMMENDATION_VENDOR=fake
LLM_RECOMMENDATION_MODEL=fake-1

# Seed users (npm run prisma:seed) — development only:
# admin@velocity.local / changeme-admin
# manager@velocity.local / changeme-manager
# operator@velocity.local / changeme-operator
